---
import '../styles/global.css';
import { Image } from 'astro:assets'; 
import logo from '../assets/logo.png';
import Navbar from '../components/navbar.astro';


import Footer from '../components/footer.astro';



// 1. Import your images from the assets folder
// Adjust these filenames to match your actual files
import domesticImg from '../assets/domestic_filter.png';
import commercialImg from '../assets/commercial_filter.png';
import industrialImg from '../assets/industrial_filter.png';
import wasteImg from '../assets/water waste treatment.png';

const products = [
  { name: "Domestic", image: domesticImg },
  { name: "Commercial",  image: commercialImg },
  { name: "Industrial",  image: industrialImg },
  { name: "Water waste Treatment",  image: wasteImg },
];
---
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Products | South Corner</title>
</head>
<body class="bg-[#f0f9ff] m-0 flex flex-col min-h-screen overflow-x-hidden">
    <Navbar />

<section class="py-16 px-6 md:px-12 bg-white">
  <div class="max-w-7xl mx-auto">
    <h2 class="text-4xl font-bold text-[#004a7c] mb-12">Products</h2>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
      {products.map((product) => (
        <div class="bg-white rounded-[2rem] shadow-xl border border-gray-50 flex flex-col p-8 transition-all duration-300 hover:shadow-2xl hover:-translate-y-1 group">
          
          <div class="flex-grow flex items-center justify-center min-h-[240px] mb-6">
            <Image 
              src={product.image} 
              alt={product.name} 
              class="max-h-[200px] w-auto object-contain group-hover:scale-105 transition-transform duration-300"
            />
          </div>

          <div class="flex justify-between items-center mt-auto border-t border-gray-100 pt-4">
            <h3 class="text-xl font-bold text-slate-800 tracking-tight">
              {product.name}
            </h3>
            
          </div>
          
        </div>
      ))}
    </div>
  </div>
</section>
<Footer />
