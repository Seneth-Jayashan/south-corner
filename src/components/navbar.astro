---
import { Image } from 'astro:assets';
import logo from '../assets/logo.png';

const pathname = new URL(Astro.url).pathname;
const currentPath = pathname.replace(/\/$/, "") || "/";

const navLinks = [
  { name: 'Home', href: '/' },
  { name: 'Products', href: '/products' },
  { name: 'About', href: '/about' },
  { name: 'Services', href: '/services' },
  { name: 'Contact', href: '/contact' },
];
---

<header class="bg-white border-b border-gray-200 sticky top-0 z-50">
  <nav class="container mx-auto px-4 md:px-6 py-4">
    <div class="flex items-center justify-between">
      <a href="/" class="flex items-center gap-3 md:gap-4 group">
        <Image 
          src={logo} 
          alt="South Corner Logo" 
          class="h-10 md:h-14 w-auto transition-transform group-hover:scale-105" 
          format="webp"
        />
        <div class="flex flex-col">
          <span class="text-lg md:text-2xl font-bold text-[#800000] leading-tight">
            SOUTH CORNER
          </span>
          <span class="text-[10px] md:text-xs text-gray-500 tracking-wider uppercase">
            Tangalle - Sri Lanka
          </span>
        </div>
      </a>

      <div class="hidden lg:flex items-center gap-8">
        <ul class="flex items-center gap-8 text-sm font-medium">
          {navLinks.map((link) => (
            <li>
              <a 
                href={link.href} 
                class={`transition-colors duration-200 ${currentPath === link.href ? "text-blue-600 font-bold" : "text-gray-700 hover:text-blue-600"}`}
              >
                {link.name}
              </a>
            </li>
          ))}
        </ul>
        <a href="tel:+94717241720" class="bg-[#0081c9] text-white text-sm font-semibold px-6 py-3 rounded-full hover:bg-blue-700 transition shadow-md">
          Request Call
        </a>
      </div>

      <button id="menu-btn" class="lg:hidden p-2 text-gray-700 focus:outline-none" aria-label="Toggle Menu">
        <svg id="menu-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
      </button>
    </div>

    <div id="mobile-menu" class="hidden lg:hidden flex flex-col pt-4 pb-2 space-y-4 border-t border-gray-100 mt-4">
      {navLinks.map((link) => (
        <a 
          href={link.href} 
          class={`text-lg font-semibold px-2 ${currentPath === link.href ? "text-blue-600" : "text-gray-700"}`}
        >
          {link.name}
        </a>
      ))}
      <a href="tel:+94717241720" class="bg-[#0081c9] text-white text-center py-3 rounded-xl font-bold mt-2">
        Call Now
      </a>
    </div>
  </nav>
</header>

<script>
  const menuBtn = document.getElementById('menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const menuIcon = document.getElementById('menu-icon');

  menuBtn?.addEventListener('click', () => {
    const isHidden = mobileMenu?.classList.contains('hidden');
    
    // Toggle Visibility
    mobileMenu?.classList.toggle('hidden');
    
    // Switch Icons
    if (menuIcon) {
      if (isHidden) {
        // Switch to X icon
        menuIcon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />';
      } else {
        // Switch back to Hamburger icon
        menuIcon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />';
      }
    }
  });
</script>